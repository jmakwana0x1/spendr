# Copy to .env.local and fill values there. Next.js loads .env.local (gitignored),
# NOT this file. Never put real secrets in this committed template.
# Leave the two NEXT_PUBLIC_ vars blank to run fully local (localStorage only).

# --- Used by the app (anon key is public by design) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- NOT read by the app. Configure these in the Supabase dashboard:
#     Authentication -> Providers -> Google -> Client ID / Client Secret.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
